APP_NAME=LDWS Backend
APP_VERSION=0.1.0
DEBUG=true

DATABASE_URL=postgresql+psycopg://username:password@localhost:5432/ldws

JWT_SECRET_KEY=
JWT_ALGORITHM=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_DISABLE_NOTIFICATION=false
TELEGRAM_PARSE_MODE=HTML
TELEGRAM_DELIVERY_STATE_FILE=storage/telegram_delivery_logs/delivery_state.json

PIPELINE_DEFAULT_SOURCE=simulated
PIPELINE_LOG_LEVEL=INFO
PIPELINE_CHECKPOINT_DIR=storage/checkpoints
PIPELINE_BATCH_SIZE=500
PIPELINE_DEFAULT_CSV_PATH=storage/temp/sample_sensor_readings.csv
PIPELINE_DEFAULT_GATEWAY_PAYLOAD_PATH=storage/temp/gateway_payload.json
PIPELINE_DEFAULT_API_URL=http://host.docker.internal:9001/mock-sensor-readings

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RAW=ldws-raw

AIRFLOW_ENABLED=false